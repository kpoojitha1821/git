   "source": [
    "habits = []\n",
    "\n",
    "while True:\n",
    "    command = input(\"Enter add,list or quit:\")\n",
    "\n",
    "    if command == \"add\":\n",
    "        habit = input(\"Enter habit:\")\n",
    "        habits.append(habit)\n",
    "\n",
    "    elif command == \"list\":\n",
    "        print(habits)\n",
    "\n",
    "    elif command == \"quit\":\n",
    "         break\n",
    "    "
   ]
